# mobius-user — Cloud Run deployment config for mobius-os-dev.
#
# Single source of truth for NON-SECRET runtime config. Secrets (JWT_SECRET,
# DB password) come from GCP Secret Manager and are wired up in
# scripts/deploy.sh via --set-secrets, not here.
#
# Plain KEY=value, one per line. Sourced by scripts/deploy.sh and fed into
# `gcloud run deploy --set-env-vars=...`.

# ── GCP project + region ────────────────────────────────────────────
GCP_PROJECT=mobius-os-dev
GCP_REGION=us-central1

# ── Cloud Run service identity ──────────────────────────────────────
SERVICE_NAME=mobius-user
SERVICE_ACCOUNT=mobius-platform-dev@mobius-os-dev.iam.gserviceaccount.com

# ── Image registry ──────────────────────────────────────────────────
AR_REPO=mobius-user
IMAGE_BASE=us-central1-docker.pkg.dev/mobius-os-dev/mobius-user/user

# ── Cloud SQL ───────────────────────────────────────────────────────
# We attach the dev Cloud SQL instance and connect via Unix socket.
CLOUDSQL_INSTANCE=mobius-os-dev:us-central1:mobius-platform-dev-db

# ── Cloud Run sizing ────────────────────────────────────────────────
RUN_MEMORY=512Mi
RUN_CPU=1
RUN_CONCURRENCY=80
RUN_TIMEOUT=120
RUN_MIN_INSTANCES=0
RUN_MAX_INSTANCES=10

# ── Optional VPC connector — not needed (no Memorystore Redis, no private IPs).
# Leave unset.
RUN_VPC_CONNECTOR=
RUN_VPC_EGRESS=

# ── Application config (env vars) ───────────────────────────────────
# Database URL template — app/main.py interpolates ${DB_PASSWORD} at startup
# from the secret-mounted env var so the secret stays in Secret Manager,
# not in this file. Cloud SQL Unix socket attached via --add-cloudsql-instances.
# The 'mobius_user' database must exist on the instance before first deploy
# (see scripts/create_db.sql or
# `gcloud sql databases create mobius_user --instance=mobius-platform-dev-db`).
USER_DATABASE_URL=postgresql+psycopg://postgres:__DB_PASSWORD__@/mobius_user?host=/cloudsql/mobius-os-dev:us-central1:mobius-platform-dev-db

# JWT lifetime knobs (secret comes from Secret Manager, see SET_SECRETS in deploy.sh).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Default tenant (dev convenience — production should provision real tenants).
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_NAME="Default Tenant"

# Google sign-in — same Web-application OAuth client that chat / extension use.
# Public value (NOT a secret); designed to be exposed to browsers.
GOOGLE_CLIENT_ID=1032922478554-cis9qh077pak9r98kp599g84ia5fbou5.apps.googleusercontent.com

# Welcome email skill chokepoint (already deployed on mobius-os-dev).
MOBIUS_EMAIL_SKILL_URL=https://mobius-email-ortabkknqa-uc.a.run.app

# Master org registry (provider-roster-credentialing) — canonical org_slug source
MOBIUS_ROSTER_URL=https://mobius-provider-roster-credentialing-ortabkknqa-uc.a.run.app

# Set-password page (chat frontend, live rev 00480) — un-gates invite/reset
# emails. Both invite and reset links = {this URL}?token=…
MOBIUS_SET_PASSWORD_URL_BASE=https://mobius-chat-ortabkknqa-uc.a.run.app/auth/set-password

# CORS — chat (and the OS extension, eventually) hits this from a different
# origin. Comma-separated. Browser preflight will reject anything not listed.
CORS_ALLOW_ORIGINS=https://mobius-chat-ortabkknqa-uc.a.run.app,http://localhost:8000

# Admin allowlist (used by /api/v1/admin/* + /admin dashboard).
# Comma-separated list of emails. Empty = admin endpoints disabled.
# v2 will replace this with a proper is_admin column on app_user.
MOBIUS_USER_ADMIN_EMAILS="alalithakumar@gmail.com,admin@mobius.dev"

# DB password to inject into USER_DATABASE_URL — see deploy.sh SET_SECRETS.
# (We could also put it in the URL but Secret Manager rotation is cleaner.)
