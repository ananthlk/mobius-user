# mobius-user configuration
# Copy to .env and fill in values

# PostgreSQL connection for user database
USER_DATABASE_URL=postgresql://postgres:password@localhost:5432/mobius_user

# JWT configuration (MUST match across all Mobius apps that share auth)
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Default tenant (for development)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_NAME=Default Tenant
